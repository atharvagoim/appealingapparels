# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Atlas: Cluster → Connect → Drivers → copy the SRV string, then set the db name.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/appealing_apparels?retryWrites=true&w=majority

# CORS — the frontend origin allowed to call this API
FRONTEND_URL=http://localhost:5173

# Auth (Phase 5)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d

# Admin user created by `npm run seed:admin`
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@appealingapparels.com
ADMIN_PASSWORD=changeme123
