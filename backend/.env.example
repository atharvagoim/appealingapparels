# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Atlas: Cluster → Connect → Drivers → copy the SRV string, then set the db name.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/appealing_apparels?retryWrites=true&w=majority

# CORS — the frontend origin allowed to call this API
# Browser origins allowed to call this API. Comma-separate several.
# Use your PRODUCTION domain — Vercel preview URLs are matched automatically,
# so you don't need to update this on every deploy.
FRONTEND_URL=https://appealingapparels.vercel.app,http://localhost:5173

# Auth (Phase 5)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES=7d

# Admin user created by `npm run seed:admin`
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@appealingapparels.com
ADMIN_PASSWORD=changeme123

# Razorpay Standard Checkout
RAZORPAY_KEY_ID=your_key_id
RAZORPAY_KEY_SECRET=your_key_secret


# --- Password-reset email ---
# Preferred: Brevo's HTTP API. Works on hosts that block outbound SMTP ports
# (Render's lower tiers do), so it behaves the same locally and in production.
#   Brevo → SMTP & API → API keys → Generate a new API key
BREVO_API_KEY=

# The sender address must be VERIFIED in Brevo → Senders, Domains & Dedicated IPs.
MAIL_FROM=appealingapparels543@gmail.com
MAIL_FROM_NAME=Appealing Apparels

# Fallback: plain SMTP, used only when BREVO_API_KEY is empty. Works with
# Brevo or any other provider.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
